<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="baseUrl" type="string" label="Base Url"/>
            <property name="cmsImage1" type="ContentReference" label="Select 1st Product Image"/>
            <property name="cmsImage2" type="ContentReference" label="Select 2nd Product Image"/>
            <property name="cmsImage3" type="ContentReference" label="Select 3rd Product Image"/>
            <property name="imageAlignment" type="string" datasource="Stretch to fit, Scale to fit" label="Image Alignment"/>
            
            <property name="minHeight" type="Integer" label="Minimum Height (px)" default="600"/>
            <property name="bannerWidth" type="Integer" label="Width (%)" default="100"/>

            <!-- static picklist for horizontal alignment -->
            <property name="horizontalAlign" type="String" label="Horizontal Alignment"
                      datasource="left,center,right" default="center"/>

            <!-- border values -->
            <property name="borderColor" type="Color" label="Border Color" default="#000000"/>
            <property name="borderWeight" type="Integer" label="Border Weight (px)" default="0"/>
            <property name="borderRadius" type="Integer" label="Border Radius (px)" default="0"/>
            <!-- Padding options -->
            <property name="padding" type="String" label="Padding"
                    datasource="None,Small,Medium,Large" default="None"/>

            <!-- Background color -->
            <property name="backgroundColor" type="Color" label="Background Color" default="#FFFFFF"/>
        </targetConfig>

    </targetConfigs>
</LightningComponentBundle>